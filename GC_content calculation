# Function for calculation of GC content
def gc_content(sequence):
    # Counting G and C nucleotides
    g = sequence.count("G")
    c = sequence.count("C")

    # Calculating G and C percentage
    return (g + c) / len(sequence) * 100


sequence =""

with open("gene.fna") as file:
    for line in file:
        if not line.startswith(">"):
           sequence +=line.strip()

print("GC_content:",
round(gc_content(sequence) , 2),
"%")
  
